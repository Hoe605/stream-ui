{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "declaration": true,
    "rootDir": ".",
    "outDir": "./dist/types",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "stream-ui": [
        "src/index.ts"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "docs/**/*.ts",
    "docs/**/*.vue",
    "docs/**/*.md",
    "play/**/*.ts",
    "play/**/*.vue"
  ]
}
