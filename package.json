{
  "name": "@huiol/stream-ui",
  "version": "0.0.2",
  "description": "一个轻量的 Vue 3 流式文本标签拦截渲染引擎",
  "type": "module",
  "bin": {
    "stream-ui": "bin/stream-ui.js"
  },
  "main": "./dist/stream-ui.umd.cjs",
  "module": "./dist/stream-ui.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/stream-ui.js",
      "require": "./dist/stream-ui.umd.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "cli",
    "src/core",
    "README_CN.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "dev": "vite",
    "build": "vite build && vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepack": "pnpm build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "docs:build": "pnpm --filter stream-ui-docs build",
    "docs:dev": "pnpm --filter stream-ui-docs dev"
  },
  "keywords": [
    "vue",
    "stream",
    "ai",
    "llm",
    "renderer",
    "headless"
  ],
  "author": "huiol",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "packageManager": "pnpm@10.21.0",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  }
}